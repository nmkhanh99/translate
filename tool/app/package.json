{
  "name": "cfa-translate-studio",
  "version": "0.1.0",
  "description": "App macOS quản lý dịch PDF CFA (giữ layout) qua Claude & Codex",
  "author": "CFA Translate",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "electron": "^33.2.0"
  },
  "build": {
    "appId": "io.cfa.translate.studio",
    "productName": "CFA Translate Studio",
    "files": [
      "main.js",
      "preload.js",
      "terminal.html",
      "vendor/**/*",
      "package.json",
      "assets/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "tool",
        "filter": [
          "**/*.py",
          "*.js",
          "*.json",
          "requirements.txt"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
