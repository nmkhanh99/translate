{
  "name": "cfa-translate-studio",
  "version": "0.2.0",
  "description": "App macOS quản lý dịch PDF CFA (giữ layout) qua Claude, Codex & Grok — UI Next.js + chat theo tài liệu",
  "author": "CFA Translate",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0"
  },
  "build": {
    "appId": "io.cfa.translate.studio",
    "productName": "CFA Translate Studio",
    "files": ["main.js", "package.json", "assets/**/*"],
    "extraResources": [
      {
        "from": "../",
        "to": "tool",
        "filter": [
          "**/*.py",
          "*.js",
          "*.json",
          "requirements.txt",
          "web/out/**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dir"]
    }
  }
}
